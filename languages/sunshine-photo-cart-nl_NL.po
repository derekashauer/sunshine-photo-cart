#: sunshine-cloud-storage/admin/tools.php:95
msgid "Change scope"
msgstr "Verander Scope"

#: sunshine-cloud-storage/admin/tools.php:99
#, php-format
msgid ""
"<strong>Note:</strong> Make sure you have at least %s of available space in "
"your cloud storage bucket."
msgstr ""
"<strong>Opmerking:</strong> Zorg ervoor dat u ten minste %s beschikbare "
"ruimte hebt in uw cloudopslagbucket."

#: sunshine-cloud-storage/admin/tools.php:108
#, php-format
msgid "All %d images are already in cloud storage. Nothing to migrate!"
msgstr "Alle %d afbeeldingen staan al in de cloudopslag. Niets om te migreren!"

#: sunshine-cloud-storage/admin/tools.php:119
#, php-format
msgid ""
"Total Images: %1$s | Already Offloaded: %2$s | Need to Offload: %3$s | Size "
